{
  "name": "react-native-ultimate-alarm",
  "version": "0.1.1",
  "description": "Unified alarm package for React Native with true alarm support on Android and iOS 16+",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "app.plugin.js",
    "expo-module.config.json",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "build": "bob build && tsc --project tsconfig.build.json --outDir lib/typescript --declaration --declarationMap --emitDeclarationOnly --noEmit false",
    "prepare": "npm run build",
    "example": "yarn --cwd example",
    "bootstrap": "yarn example && yarn install"
  },
  "keywords": [
    "react-native",
    "expo",
    "alarm",
    "alarmkit",
    "notification",
    "reminder",
    "wake-up",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kbanta11/react-native-ultimate-alarm.git"
  },
  "author": "Kyle Banta <kbantadevelopment@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kbanta11/react-native-ultimate-alarm/issues"
  },
  "homepage": "https://github.com/kbanta11/react-native-ultimate-alarm#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@react-native-community/eslint-config": "^3.2.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.51.0",
    "expo-modules-core": "^2.2.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.2.0"
  },
  "peerDependencies": {
    "expo": "^54.0.0",
    "expo-modules-core": "^3.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module"
    ]
  }
}
